# ============================================
# GenBa Note - Environment Variables Template
# ============================================
# このファイルをコピーして .env を作成してください
# Copy this file to create .env
#
# 重要: 実際の値を入力する前に、以下のルールを確認してください
# - 秘密情報は絶対にGitにコミットしないこと
# - .env ファイルは .gitignore に含まれていることを確認すること
# ============================================

# ------------------------------------------
# App Environment
# ------------------------------------------
# アプリの実行環境を指定
# Options: development, staging, production
#
# Pro機能 (PDF出力・CSVエクスポート) への影響:
# - development/staging: Pro機能が自動有効化（IAP不要）
# - production: RevenueCatによる購入検証が必須
#
# 注意: App Store提出ビルドでは必ず production を設定すること
EXPO_PUBLIC_APP_ENV=

# ------------------------------------------
# RevenueCat (Subscription Management)
# ------------------------------------------
# RevenueCat Public SDK Key - クライアントサイドSDK用の公開キー
# (注意: これは公開キーです。秘密キーではありません)
# Get from: https://app.revenuecat.com/ > Project Settings > API Keys
EXPO_PUBLIC_REVENUECAT_PUBLIC_KEY=

# ------------------------------------------
# Supabase (Material Research API Proxy)
# ------------------------------------------
# Supabase プロジェクトURL
# Get from: https://supabase.com/dashboard > Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=

# Supabase Anonymous Key - クライアントサイド用の公開キー
# (注意: これは公開キーです。秘密キーではありません)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ------------------------------------------
# API Configuration (Future)
# ------------------------------------------
# バックエンドAPIのベースURL（将来のAPI接続用）
# EXPO_PUBLIC_API_BASE_URL=

# API認証キー（将来のAPI接続用）
# API_KEY=

# ------------------------------------------
# AI/Image Generation (Future)
# ------------------------------------------
# AI機能を有効にするかどうか
# EXPO_PUBLIC_AI_ENABLED=

# AIプロバイダー (openai, anthropic, azure, etc.)
# EXPO_PUBLIC_AI_PROVIDER=

# AI API Key - サーバーサイドでのみ使用
# AI_API_KEY=

# AI API Endpoint (optional, for custom endpoints)
# AI_API_ENDPOINT=

# ------------------------------------------
# Analytics & Debugging (Future)
# ------------------------------------------
# アナリティクスを有効にするかどうか
# EXPO_PUBLIC_ANALYTICS_ENABLED=

# デバッグログを有効にするかどうか
# EXPO_PUBLIC_DEBUG_MODE=
